# ── Base de datos PostgreSQL ────────────────────────────────────────────────
DB_HOST=<host>
DB_NAME=<database>
DB_USER=<user>
DB_PASSWORD=<password>
DB_PORT=5432

# ── Destino en PostgreSQL ────────────────────────────────────────────────────
# PRESUPUESTO_SCHEMA: schema para la tabla temporal (staging)
# DB_TARGET_SCHEMA:   schema donde vive la tabla destino final
PRESUPUESTO_SCHEMA=<staging-schema>
DB_TARGET_SCHEMA=<target-schema>
PRESUPUESTO_TABLE=<table>

# ── Configuración de columnas ─────────────────────────────────────────────────
# Clave primaria / columna de conflicto para UPSERT
SYNC_KEY=<primary-key-column>

# Columnas requeridas del Excel (separadas por coma, en el orden de la tabla destino)
REQUIRED_COLUMNS=<col1,col2,col3,...>

# Columnas que deben castearse a DATE en el INSERT
DATE_COLUMNS=<date_col1,date_col2>

# Columnas numéricas a las que se aplica ceil()
CEIL_COLUMNS=<numeric_col1,numeric_col2>

# Renombrado de columna: NombreOriginalEnExcel|nombre_interno
COLUMN_RENAME_MAP=<Original Column Name|internal_name>

# Columnas temporales a eliminar después de normalizar (separadas por coma)
DROP_COLUMNS=<temp_col1,temp_col2>

# ── Excel fuente ─────────────────────────────────────────────────────────────
# Local  : ruta absoluta al archivo    → C:\path\to\file.xlsx
# AWS/ECS: ruta temporal del container → /tmp/source_file.xlsx
PRESUPUESTO_EXCEL_PATH=<ruta_destino_xlsx>

# Nombre exacto de la hoja (sensible a mayúsculas y espacios)
EXCEL_SHEET=<nombre_hoja>

# ── Azure Entra ID / SharePoint ───────────────────────────────────────────────
SHAREPOINT_TENANT_ID=<tenant-id>
SHAREPOINT_CLIENT_ID=<application-client-id>
SHAREPOINT_CLIENT_SECRET=<client-secret-value>
SHAREPOINT_DRIVE_ID=<sharepoint-drive-id>
SHAREPOINT_ITEM_ID=<excel-item-id>

# Las siguientes variables están definidas pero NO son leídas por el pipeline
# SHAREPOINT_SITE_ID=<site-id>  # no utilizado por el ETL (solo referencia)
# URL=<graph-api-url>            # URL de descarga completa (solo referencia manual)
# OUTPUT_FILENAME=<filename>     # no utilizado por el ETL
